<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/Midnight_MainActivity_WelcomeScreen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".VehicleConsumptionActivity">

    <View
        android:id="@+id/ViewFeulPriceScreen"
        android:layout_width="wrap_content"
        android:layout_height="200dp"
        android:background="@drawable/bg_rouded"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="233dp"
        android:layout_height="209dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="82dp"
        app:layout_constraintEnd_toEndOf="@+id/ViewFeulPriceScreen"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/ViewFeulPriceScreen"
        app:srcCompat="@drawable/ic_vehicleconsumption_screen" />

    <TextView
        android:id="@+id/edt_LabelVehicleConsumption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="24dp"
        android:text="Consumo por Litro"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ViewFeulPriceScreen" />

    <EditText
        android:id="@+id/edtVehicleConsumption"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        android:background="@color/edtBlue"
        android:ems="10"
        android:hint="Ex: 15"
        android:inputType="number"
        android:textColor="@color/white"
        android:textColorHint="@color/edtTintbluen"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edt_LabelVehicleConsumption" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_VoltarVehicleConsumption"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="32dp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="15sp"
        android:background="@drawable/bg_button"
        android:text="Voltar"
        app:backgroundTint="@null"
        app:icon="@drawable/ic_arrow_back"
        app:iconTint="@color/white"
        app:iconGravity="textStart"
        app:iconPadding="10dp"
        app:iconSize="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btn_ProximoVehicleConsumption"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_ProximoVehicleConsumption"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button"
        android:text="Proximo"
        app:backgroundTint="@null"
        app:icon="@drawable/ic_arrow_forward"
        app:iconGravity="textStart"
        app:iconPadding="10dp"
        app:iconSize="28dp"
        app:iconTint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/btn_VoltarVehicleConsumption" />
</androidx.constraintlayout.widget.ConstraintLayout>